{
  "name": "legacy-proxy",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "IMAP/SMTP/ManageSieve to JMAP gateway. Speaks JMAP for Mail (RFC 8620 / 8621) on the front, IMAP4rev1 + Submission + ManageSieve on the back, so any JMAP client can talk to a legacy mailserver.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "setup": "node scripts/setup.mjs",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:compliance": "node scripts/run-compliance.mjs",
    "test:all": "npm run test && npm run test:integration && npm run test:compliance"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^11.5.0",
    "fastify": "^5.1.0",
    "imapflow": "^1.0.165",
    "mailparser": "^3.7.1",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
